[Trigger]
Operation = Install
Operation = Upgrade
Type = Package
Target = linux
Target = intel-ucode

[Action]
Description = Syncing this host's boot entry from dotfiles...
When = PostTransaction
Exec = /bin/sh -c 'cp "/home/walker/.config/hosts/$(cat /etc/hostname)/boot/loader/entries/arch.conf" /boot/loader/entries/arch.conf'
