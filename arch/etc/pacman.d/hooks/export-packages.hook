# Auto-export package lists after install/remove
[Trigger]
Operation = Install
Operation = Remove
Type = Package
Target = *

[Action]
When = PostTransaction
Exec = /bin/sh -c 'H=$(cat /etc/hostname); pacman -Qqen > "/home/walker/.config/hosts/$H/packages-pacman.txt"; pacman -Qqem > "/home/walker/.config/hosts/$H/packages-aur.txt"'
