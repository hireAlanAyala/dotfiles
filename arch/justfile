# Arch Linux system configuration
# Run `just` to see available recipes

set shell := ["bash", "-euo", "pipefail", "-c"]
set quiet

dir := justfile_directory()

# Full system setup
all: etc sudoers systemd firewall bin dotfiles shell tmux-plugins

# /etc symlinks and configs
# Only tracks customized configs - the rest of /etc stays system-managed
etc:
    sudo cp "{{dir}}/etc/pacman.conf" /etc/pacman.conf
    sudo mkdir -p /etc/boot /etc/pacman.d /etc/systemd
    sudo ln -sfn "{{dir}}/etc/bluetooth" /etc/bluetooth
    sudo ln -sfn "{{dir}}/../hosts/$(hostnamectl hostname)/boot/loader" /etc/boot/loader
    sudo ln -sfn "{{dir}}/etc/pacman.d/hooks" /etc/pacman.d/hooks
    sudo ln -sf "{{dir}}/etc/systemd/zram-generator.conf" /etc/systemd/zram-generator.conf
    sudo mkdir -p /etc/systemd/network /etc/systemd/system
    sudo cp "{{dir}}"/etc/systemd/network/*.network /etc/systemd/network/
    sudo cp "{{dir}}"/etc/systemd/system/*.{service,timer} /etc/systemd/system/
    sudo install -m 644 -o root -g root "{{dir}}/etc/tlp/tlp.conf" /etc/tlp.conf
    sudo mkdir -p /etc/systemd/sleep.conf.d /etc/systemd/logind.conf.d
    sudo ln -sf "{{dir}}/etc/systemd/sleep.conf.d/hibernate.conf" /etc/systemd/sleep.conf.d/hibernate.conf
    sudo ln -sf "{{dir}}/etc/systemd/logind.conf.d/lid.conf" /etc/systemd/logind.conf.d/lid.conf

# Allow wheel group to use sudo
# Generated instead of symlinked to avoid tracking root-owned files in git
# pwfeedback echoes '*' per keystroke so you can see the password registering
sudoers:
    printf '%%wheel ALL=(ALL:ALL) ALL\nDefaults pwfeedback\n' | sudo tee /etc/sudoers.d/wheel > /dev/null
    sudo chmod 440 /etc/sudoers.d/wheel

# Systemd services (system + user)
systemd: systemd-symlinks systemd-system systemd-user

# Symlink user units
systemd-symlinks:
    mkdir -p ~/.config/systemd/user
    ln -sf "{{dir}}"/systemd/user/*.{service,timer} ~/.config/systemd/user/
    systemctl --user daemon-reload

# Enable system services (shared, then per-host)
systemd-system:
    -sudo systemctl disable --now NetworkManager
    sudo systemctl enable --now iwd systemd-networkd systemd-resolved
    sudo ln -sf /run/systemd/resolve/stub-resolv.conf /etc/resolv.conf
    -sudo systemctl enable --now bluetooth fstrim.timer earlyoom reflector.timer ufw pacman-sync.timer tailscaled
    -sudo systemctl mask systemd-rfkill.service systemd-rfkill.socket
    -just -f "{{justfile()}}" "_systemd-system-$(hostnamectl hostname)"

# Per-host system services
_systemd-system-homebase:
    @true

_systemd-system-archdev:
    -sudo systemctl enable --now tlp.service

# Enable user services (shared, then per-host)
systemd-user:
    -systemctl --user enable pipewire pipewire-pulse wireplumber p11-kit-server.socket
    -systemctl --user enable elephant.service pipewire-session-manager.service cache-cleanup.timer phone-term.service scrub-downloads.service
    -just -f "{{justfile()}}" "_systemd-user-$(hostnamectl hostname)"

# Per-host user services
_systemd-user-homebase:
    -systemctl --user enable sunshine rustic-backup.timer

_systemd-user-archdev:
    -systemctl --user enable battery-monitor.timer wifi-prefer.timer

# UFW firewall rules
firewall:
    sudo ufw default deny incoming
    sudo ufw default allow outgoing
    sudo ufw allow ssh
    sudo ufw allow 53317/udp
    sudo ufw allow 53317/tcp
    sudo ufw allow in on tailscale0 comment 'allow-tailscale'
    sudo ufw allow in proto udp from 172.16.0.0/12 to 172.17.0.1 port 53 comment 'allow-docker-dns'
    sudo ufw --force enable

# Docker UFW integration (run after docker installed)
firewall-docker:
    sudo ufw-docker install
    sudo ufw reload

# Install official repo packages
packages:
    grep -v '^#\|^\s*$' "{{dir}}/../hosts/$(hostnamectl hostname)/packages-pacman.txt" | sudo pacman -S --needed -

# Install AUR packages (requires yay)
packages-aur:
    grep -v '^#\|^\s*$' "{{dir}}/../hosts/$(hostnamectl hostname)/packages-aur.txt" | yay -S --needed -

# Install all packages (pacman + AUR)
packages-all: packages packages-aur

# Symlink bin scripts
bin:
    mkdir -p ~/.local/bin
    for f in "{{dir}}"/bin/*; do chmod +x "$f"; ln -sf "$f" ~/.local/bin/; done

# Clone tmux plugins (Dracula theme, loaded by ~/.config/tmux/tmux.conf)
tmux-plugins:
    mkdir -p ~/.config/tmux/plugins
    test -d ~/.config/tmux/plugins/dracula || git clone --depth 1 --branch v3.1.0 https://github.com/dracula/tmux ~/.config/tmux/plugins/dracula

# Symlink shell rc files into $HOME (zsh + bash entry points)
shell:
    ln -sf "{{dir}}/../zsh/.zshenv" ~/.zshenv
    ln -sf "{{dir}}/../zsh/.zshrc" ~/.zshrc
    ln -sf "{{dir}}/../zsh/.zprofile" ~/.zprofile
    ln -sf "{{dir}}/../bash/.bashrc" ~/.bashrc
    ln -sf "{{dir}}/../bash/.bash_profile" ~/.bash_profile
    ln -sf "{{dir}}/../bash/.profile" ~/.profile

# Symlink dotfiles that must live outside ~/.config (ssh + claude + gpg)
dotfiles:
    mkdir -p ~/.ssh ~/.claude
    ln -sf "{{dir}}/../.ssh/config" ~/.ssh/config
    ln -sf "{{dir}}/../.ssh/authorized_keys" ~/.ssh/authorized_keys
    ln -sf "{{dir}}/../claude/settings.json" ~/.claude/settings.json
    ln -sf "{{dir}}/../claude/.mcp.json" ~/.claude/.mcp.json
    ln -sfn "{{dir}}/../claude/commands" ~/.claude/commands
    ln -sf "{{dir}}/../claude/CLAUDE.md" ~/.claude/CLAUDE.md
    mkdir -p ~/.gnupg && chmod 700 ~/.gnupg
    ln -sf "{{dir}}/../gnupg/gpg.conf" ~/.gnupg/gpg.conf
    ln -sf "{{dir}}/../gnupg/gpg-agent.conf" ~/.gnupg/gpg-agent.conf

# Show what will be linked
check:
    @echo "etc: pacman.conf bluetooth boot/loader pacman.d/hooks systemd/zram-generator.conf tlp"
    @echo "systemd/user:" && ls "{{dir}}/systemd/user/"
    @echo "bin:" && ls "{{dir}}/bin/"
