#!/usr/bin/env bash
# pre-push: BLOCK if installed packages drifted from tracked desired-state.
# Escape hatch: `git push --no-verify` to push anyway (a conscious choice, not a slip).
cd "$(git rev-parse --show-toplevel)/arch" || exit 0
command -v just >/dev/null 2>&1 || exit 0
drift=$(just packages-check 2>/dev/null | grep -E 'MISSING|ORPHAN')
[ -z "$drift" ] && exit 0
{
  echo ""
  echo "⚠  package list is stale vs what's actually installed:"
  echo "$drift" | sed 's/^/      /'
  h=$(hostnamectl hostname)
  echo "   → run 'just packages-sync' to bless $h's state, or edit packages/$h.txt / $h-aur.txt"
  echo "   (push blocked — fix it, or 'git push --no-verify' to override)"
  echo ""
} >&2
exit 1
