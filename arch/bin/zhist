#!/usr/bin/env zsh
# Emit shell-history entries as NUL-delimited records, most-recent-first, deduped.
#
# Decoding goes through zsh's own history parser (fc -R into an isolated process),
# so extended-history timestamps are stripped and multi-line commands stay intact.
# Records are NUL-separated for safe consumption by `fzf --read0`.
#
#   zhist --all       aggregate of every ~/.zsh_history* file
#   zhist <file>...    only the given history file(s)
#
# Ordering: files are read oldest-mtime first so the most recently used file's
# entries get the highest event numbers; emitting by descending event number then
# puts the newest command of the most-recently-active terminal at the top.

emulate -L zsh
setopt nullglob

local -a files
if [[ $1 == --all ]]; then
  files=( ~/.zsh_history*(Om) )
else
  files=( "$@" )
fi

HISTSIZE=1000000
SAVEHIST=0
local f
for f in $files; do
  [[ -r $f ]] && fc -R -- "$f" 2>/dev/null
done

local -A seen
local k cmd
for k in ${(nO)${(k)history}}; do
  cmd=$history[$k]
  [[ -n $cmd && -z $seen[$cmd] ]] || continue
  seen[$cmd]=1
  print -rN -- "$cmd"
done
