{
  "env": {
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_BUG_COMMAND": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "TodoWrite"
    ],
    "deny": [
      "Read(**/.ssh/**)",
      "Read(**/.aws/**)",
      "Read(**/.azure/**)",
      "Read(**/.gnupg/**)",
      "Read(**/secrets.*)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Write(**/.ssh/**)",
      "Edit(**/.ssh/**)",
      "Write(/etc/**)",
      "Edit(/etc/**)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME)",
      "Bash(sudo rm -rf:*)",
      "Bash(rm -rf --no-preserve-root:*)",
      "Bash(mkfs:*)",
      "Bash(wipefs:*)",
      "Bash(fdisk:*)",
      "Bash(parted:*)",
      "Bash(shred:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(halt:*)",
      "Bash(poweroff:*)",
      "Bash(chmod -R 777:*)",
      "Bash(chmod 777 /:*)"
    ],
    "ask": [
      "Bash(sudo:*)",
      "Bash(dd:*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Write(**/*.env*)"
    ],
    "defaultMode": "acceptEdits",
    "additionalDirectories": [
      "~/.config"
    ]
  },
  "enableAllProjectMcpServers": true,
  "statusLine": {
    "type": "command",
    "command": "bash /home/walker/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "lua-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "medium",
  "skipDangerousModePermissionPrompt": true
}
